# PATHS
ADULT_DATA_PATH=data/adult.csv
GERMAN_DATA_PATH=data/german.csv
LAW_DATA_PATH=data/law.csv

# DATA
ADULT_TARGET="income"
GERMAN_TARGET="good_3_bad_2_customer"
LAW_TARGET="pass_bar"

# SAVE PATHS
MODEL_SAVE_PATH="model_state.pth"
HIST_SAVE_PATH_0="histogram_g0.csv"
HIST_SAVE_PATH_1="histogram_g1.csv"
LH_G0_H0="likelihoods_g0_h0.csv"
LH_G0_H1="likelihoods_g0_h1.csv"
LH_G1_H0="likelihoods_g1_h0.csv"
LH_G1_H1="likelihoods_g1_h1.csv"

# LOGGING
LOG_LEVEL="info"
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"

# FILE READER
# Contribs
CONTRIBS_HEADER=inputId:int,layerId:int,nodeId:int,nodeContrib:float
CONTRIB_INPUT_POS=0
CONTRIB_LAYER_POS=1
CONTRIB_NODE_POS=2
CONTRIB_VALUE_POS=3
# Histograms
HIST_HEADER=nodeId:int,binId:int,sigmaInterval_lb:float,sigmaInterval_ub:float,sigmaFreq:int
HIST_NODE_POS=0
HIST_BIN_POS=1
HIST_LB_POS=2
HIST_UB_POS=3
HIST_FREQ_POS=4
# Indexes
INDEXES_HEADER=inputId:int,TrueClass:int,PredictedClass:int,SensitiveAttr:int,SetName:str
INDEX_INPUT_ID_POS=0
TRUE_CLASS_POS=1
PRED_CLASS_POS=2
SENS_ATTR_POS=3
SET_NAME_POS=4
# Likelihood
LH_HEADER=inputId:int,Score:float
LH_INPUT_ID_POS=0
SCORE_POS=1

# CALCUL
# Number of decimal to display (round number after 5th decimal)
DISPLAY_PREC=4
# Difference between float 'f' and the least value greater than 'f' that is representable as a float.
EPSILON=1e-10
# Used in context when we need finer estimation
LOW_SMOOTHED_PROB=1e-15
# Max possible int
POS_UNDEF_INT=9999